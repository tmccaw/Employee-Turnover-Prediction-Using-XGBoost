   "source": [
    "#### XGBoost Model"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "F1-score was choosen as the main evaluation metric for this model because of the imbalance in the target variable."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 27,
   "metadata": {
    "id": "UePZZyi_Okdz"
   },
   "outputs": [],
   "source": [
    "# Instantiate the XGBoost model\n",
    "# objective='binary:logistic': Specifies the binary classification task with logistic regression\n",
    "xgb = XGBClassifier(objective='binary:logistic', random_state=42) \n",
    "\n",
    "# Define the Cross Validation parameters\n",
    "cv_params = {'max_depth': [4,5,6,7,8], \n",
    "             'min_child_weight': [1,2,3,4,5],\n",
    "             'learning_rate': [0.1, 0.2, 0.3],\n",
    "             'n_estimators': [75, 100, 125]\n",
    "             }    \n",
    "\n",
    "# Define the scoring metrics\n",
    "scoring = {'accuracy', 'precision', 'recall', 'f1'}\n",
    "\n",
    "# Instantiate the GridSearch\n",
    "xgb_cv = GridSearchCV(xgb, cv_params, scoring=scoring, cv=5, refit='f1', verbose=3, n_jobs=os.cpu_count() - 1)"
   ]
  },
