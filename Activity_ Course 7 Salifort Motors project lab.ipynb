    "                                               stratify=y)\n",
    "\n",
    "# Split into train and validation sets\n",
    "X_train, X_val, y_train, y_val = train_test_split(X_tr, y_tr, \n",
    "                                               test_size=.25, \n",
    "                                               random_state=42,\n",
    "                                               stratify=y_tr)"
